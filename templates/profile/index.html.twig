{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil
{% endblock %}

{% block body %}
	<div class="container pt-5">
		<div class="card card-fill">
			<div class="card-body">
				<div class="my-8 mx-auto w-100">
					<h1 class="text-center mb-4 fs-4">Modifier mon profil</h1>
					{{ form_errors(form) }}

					{{ form_start(form) }}
					<div class="row">
						<div class="col-md-12">
							{{ form_row(form.email, {'attr': {'class': 'form-control-login'}}) }}
						</div>
						{# <div class="col-md-6">
							{{ form_row(form.plainPassword, {'attr': {'class': 'form-control-login'}}) }}
							{% include "partials/_entropy.html.twig" %}
						</div> #}
					</div>
					<div class="row">
						<div class="col-md-6">
							{{ form_row(form.firstname, {'attr': {'class': 'form-control-login'}}) }}
						</div>
						<div class="col-md-6">
							{{ form_row(form.lastname, {'attr': {'class': 'form-control-login'}}) }}
						</div>
					</div>
					<div class="row">
						<div class="col-md-6">
							{{ form_row(form.phone, {'attr': {'class': 'form-control-login'}}) }}
						</div>
						<div class="col-md-6">
							{{ form_row(form.adress, {'attr': {'class': 'form-control-login'}}) }}
							{{ form_row(form.postalCode, {'attr': {'class': 'form-control-login'}}) }}
							{{ form_row(form.city, {'attr': {'class': 'form-control-login'}}) }}
						</div>
					</div>
					<button id="submit-button" type="submit" class="btn btn-md btn-dark">
						<span>Modifier</span>
					</button>
                    {{ form_end(form) }}
				</div>
			</div>
		</div>
	</div>
{% endblock %}